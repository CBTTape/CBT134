FOUNDSEC DC    0H                      NAME FOUND IN TABLE
         MVC   DBL+1(1),$SECNMLN-4(R2) COPY OPTION FLAGS
         MVC   DBL+3(1),$SECNMLN-3(R2) COPY SECTION LEVEL
         MVC   DBL+6(2),$SECNMLN-2(R2) COPY INDICATOR OFFSET
         TM    $SECNMLN-3(R2),X'80'    LAST SECTION OF RECORD?
         BO    SECOPTS                 YES
         MVI   53(R1),C','             NO, SUPPLY NEXT SECTION NAME
         MVC   54($SECNMLN-3,R1),$SECNMLN(R2)
SECOPTS  DC    0H                      NAME FOUND IN TABLE
         LH    R4,DBL                  LOAD FLAGS
         LH    R5,DBL+2                LOAD LEVEL
         L     R6,DBL+4                LOAD OFFSET
         CVD   R4,DBL
         OI    DBL+7,X'0F'             PREPARE FOR UNPACK
         UNPK  40(3,R1),DBL            APPEND DECIMAL BYTE VALUE
         MVI   43(R1),C','
         CVD   R5,DBL
         OI    DBL+7,X'0F'             PREPARE FOR UNPACK
         UNPK  44(3,R1),DBL            APPEND DECIMAL BYTE VALUE
         MVI   47(R1),C','
         CVD   R6,DBL
         OI    DBL+7,X'0F'             PREPARE FOR UNPACK
         UNPK  48(5,R1),DBL            APPEND DECIMAL OFFSET VALUE
         LA    R15,4                   SUPPRESS UP TO 4 LEADING ZEROES
         LA    R14,2                   SUPPRESS UP TO 2 LEADING ZEROES
         LA    R6,2                    SUPPRESS UP TO 2 LEADING ZEROES
ZERO_LP3 DC    0H
         CLI   48(R1),C'0'             LEADING ZERO IN DECIMAL OFFSET?
         BNE   ZERO_LP4                NO
         MVC   48(16,R1),49(R1)        YES, SUPPRESS IT
         BCT   R15,ZERO_LP3
ZERO_LP4 DC    0H
         CLI   40(R1),C'0'             LEADING ZERO IN DECIMAL LEVEL?
         BNE   ZERO_LP5                NO
         MVC   44(20,R1),45(R1)        YES, SUPPRESS IT
         BCT   R14,ZERO_LP4
ZERO_LP5 DC    0H
         CLI   40(R1),C'0'             LEADING ZERO IN DECIMAL FLAGS?
         BNE   ZEROS_GD                NO
         MVC   40(24,R1),41(R1)        YES, SUPPRESS IT
         BCT   R6,ZERO_LP5
ZEROS_GD DC    0H
         CLC   =CL2'  ',14(R1)         OKAY TO MOVE VERB TO COLUMN 16?
         BNE   SECTDONE                NO
         LA    R15,15(,R1)             YES, POINT TO IT
         CLC   =CL2'  ',8(R1)          OKAY TO MOVE VERB TO COLUMN 10?
         BNE   *+8                     NO
         LA    R15,9(,R1)              YES, POINT TO IT
         MVC   0(38,R15),32(R1)        IMPROVE STATEMENT TEXT ALIGNMENT
         MVC   47(25,R1),46(R1)        BLANK OUT SOURCE LOCATIONS
SECTDONE DC    0H                      NAME FOUND IN TABLE
         CLC   =CL6'SMFRCD',0(R1)      NEW SMF RECORD?
         BNE   SMFRCDOK                NO

