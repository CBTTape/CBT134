*  COMMENTS EXTRACTION ROUTINE

*  R13 -> REGISTER SAVE AREA
*  R14 -> RETURN POINT
*  DBL -- USED AS A WORK AREA
GET_CMTS DC    0H
         STM   R14,R12,12(R13)         SAVE REGISTERS
         LA    R14,72(,R13)            POINT TO NEXT SAVE AREA
         ST    R13,4(,R14)             CHAIN THEM
         ST    R14,8(,R13)
         LR    R13,R14                 ACTIVATE NEW SAVE AREA

         MVC   CARD,BLANK              BLANK OUTPUT BUFFER
         MVC   CARD+9(12),=CL12'DC    AL2(0)'
         MVC   CARD+39(11),=CL11'NO COMMENTS'

         TM    FLAGS1,$EOF             END-OF-FILE REACHED?
         BO    DONE_CMT                YES, SKIP COMMENTS
         CLI   PRT_LINE+41,C' '        NAMED ITEM?
         BE    DONE_CMT                NO, SKIP COMMENTS
         CLI   PRT_LINE+39,C'0'        IS LINE AN ASSEMBLER STATEMENT?
         BL    DONE_CMT                NO, SKIP COMMENTS

         NI    FLAGS1,255-$QOT         NOT WITHIN QUOTED TEXT
         AP    ITEM_NUM,=PL1'1'        INCREMENT ITEM NUMBER
         UNPK  DBL,ITEM_NUM
         OI    DBL+7,X'F0'             ENSURE NUMERIC EBCDIC
         MVI   CARD+19,C'E'            NAME END LABEL
         MVC   CARD+20(6),DBL+2
         MVI   CARD+26,C'-'
         MVI   CARD+27,C'S'            NAME START LABEL
         MVC   CARD+28(6),DBL+2
         MVI   CARD+34,C')'
         PUT   OUTDCBW,CARD
         MVC   CARD+39(18),=CL18'LENGTH OF COMMENTS'

         MVC   CARD,BLANK              BLANK OUTPUT BUFFER
         MVI   CARD,C'S'               CONSTRUCT COMMENT START LABEL
         MVC   CARD+1(6),DBL+2
         MVC   CARD+9(3),=CL3'EQU'
         MVI   CARD+15,C'*'
         PUT   OUTDCBW,CARD            WRITE COMMENT START LABEL

         LA    R0,PRT_LINE+41+71       POINT PAST POSSIBLE COMMENT
         LA    R1,PRT_LINE+41          POINT TO ITEM LABEL
CMT_LP_1 DC    0H
         CLI   0(R1),C' '              PAST ITEM LABEL?
         BE    CMT_LP_2                YES
         LA    R1,1(,R1)               NO, POINT TO NEXT CHARACTER
         CR    R1,R0                   REACHED END OF LINE?
         BL    CMT_LP_1                NO, LOOK AT CHARACTER
         B     CMT_ITEM                YES, SKIP ITEM COMMENTS
CMT_LP_2 DC    0H
         CLI   0(R1),C' '              FOUND STATEMENT VERB?
         BNE   CMT_LP_3                YES
         LA    R1,1(,R1)               NO, POINT TO NEXT CHARACTER
         CR    R1,R0                   REACHED END OF LINE?
         BL    CMT_LP_2                NO, LOOK AT CHARACTER
         B     CMT_ITEM                YES, SKIP ITEM COMMENTS
CMT_LP_3 DC    0H
         CLI   0(R1),C' '              PAST STATEMENT VERB?
         BE    CMT_LP_4                YES
         LA    R1,1(,R1)               NO, POINT TO NEXT CHARACTER
         CR    R1,R0                   REACHED END OF LINE?
         BL    CMT_LP_3                NO, LOOK AT CHARACTER
         B     CMT_ITEM                YES, SKIP ITEM COMMENTS
CMT_LP_4 DC    0H
         CLI   0(R1),C' '              FOUND STATEMENT OPERAND?
         BNE   CMT_LP_5                YES
         LA    R1,1(,R1)               NO, POINT TO NEXT CHARACTER
         CR    R1,R0                   REACHED END OF LINE?
         BL    CMT_LP_4                NO, LOOK AT CHARACTER
         B     CMT_ITEM                YES, SKIP ITEM COMMENTS
CMT_LP_5 DC    0H
         TM    FLAGS1,$QOT             WITHIN QUOTED TEXT?
         BO    QOT_LP_5                YES
         CLI   0(R1),C' '              PAST STATEMENT OPERAND(S)?
         BE    CMT_LP_6                YES
QOT_LP_5 DC    0H
         CLI   0(R1),C''''             IS THIS A QUOTE?
         BNE   NXT_LP_5                NO
         XI    FLAGS1,$QOT             YES, TOGGLE STATUS
NXT_LP_5 DC    0H
         LA    R1,1(,R1)               NO, POINT TO NEXT CHARACTER
         CR    R1,R0                   REACHED END OF LINE?
         BL    CMT_LP_5                NO, LOOK AT CHARACTER
         B     CMT_ITEM                YES, SKIP ITEM COMMENTS
CMT_LP_6 DC    0H
         CLI   0(R1),C' '              FOUND A COMMENT OPERAND?
         BNE   HAVE_CMT                YES
         LA    R1,1(,R1)               NO, POINT TO NEXT CHARACTER
         CR    R1,R0                   REACHED END OF LINE?
         BL    CMT_LP_6                NO, LOOK AT CHARACTER
         B     CMT_ITEM                YES, SKIP ITEM COMMENTS
HAVE_CMT DC    0H
         CLI   0(R1),C'@'              MERELY A CHANGE TAG?
         BE    CMT_ITEM                YES, SKIP ITEM COMMENTS
         CLC   =CL2'Y0',0(R1)          MERELY A CHANGE TAG?
         BE    CMT_ITEM                YES, SKIP ITEM COMMENTS
         TR    PRT_LINE,DCTR_TAB       REMOVE AMPERSANDS AND QUOTES
         MVC   CARD,BLANK              BLANK OUTPUT BUFFER
         MVC   CARD+1(5),=CL5'DC C'''  CONSTRUCT DC STATEMENT
         LA    R14,CARD+6              POINT TO TARGET
LOAD_CMT DC    0H
         MVC   0(1,R14),0(R1)          LOAD COMMENT CHARACTER
         LA    R14,1(,R14)             ADJUST TARGET
         LA    R1,1(,R1)               ADJUST SOURCE
         CR    R1,R0                   REACHED END OF LINE?
         BNL   CMT_LINE                YES
         CLI   0(R1),C'@'              REACHED CHANGE TAG?
         BE    CMT_LINE                YES, SKIP ITEM COMMENTS
         CLC   =CL2'Y0',0(R1)          REACHED CHANGE TAG?
         BNE   LOAD_CMT                NO, LOAD ANOTHER CHARACTER
CMT_LINE DC    0H                      COMMENT LINE COMPLETE
         BCTR  R14,0                   BACK UP ONE CHARACTER
         CLI   0(R14),C' '             TRAILING BLANK?
         BE    CMT_LINE                YES, TRUNCATE IT
         LA    R15,CARD+6              POINT TO TARGET
         CLR   R14,R15                 ANY YIELD?
         BNH   CMT_NEXT                NO, IGNORE EMPTY COMMENT LINE
         MVC   1(7,R14),=CL7''',X''15'''    TERMINATE THE LINE
         MVC   CARDHOLD,CARD           COPY OUTPUT RECORD
         CLC   CARD+61(19),CARD+60     11 TRAILING BLANKS?
         MVC   CARD,BLANK              BLANK OUTPUT BUFFER
         MVC   CARD+9(2),=CL5'DC C'''  CREATE DC STMT (REUSE LITERAL)
         BE    DO_ALIGN                YES, ALIGN DC DATA NICELY
         MVC   CARD+15(37),CARDHOLD+4  COPY 35 BYTES OF TEXT
         MVI   CARD+15+37,C''''        APPEND TRAILING QUOTE
         PUT   OUTDCBW,CARD            WRITE START OF THE COMMENT LINE
         MVC   CARD+17(44),CARDHOLD+41 COPY THE REST OF THE TEXT AND NL
         B     ALIGN_OK                GO WRITE REST OF COMMENT LINE
DO_ALIGN DC    0H                      COMMENT LINE COMPLETE
         MVC   CARD+15(65),CARDHOLD+4  COPY CONSTANT (DC OPERAND)
ALIGN_OK DC    0H                      COMMENT LINE COMPLETE
         PUT   OUTDCBW,CARD            WRITE THE COMMENT LINE

CMT_NEXT DC    0H                      COMMENT LINE COMPLETE
         TM    FLAGS1,$EOF             END-OF-FILE REACHED?
         BO    CMT_ITEM                YES
         GET   INDCBW,PRT_LINE         GET ASSEMBLER PRINT LINE
         CLI   PRT_LINE+39,C'0'        IS LINE AN ASSEMBLER STATEMENT?
         BL    CMT_NEXT                NO, GET NEXT LISTING LINE
         CLI   PRT_LINE+41,C'*'        IS LINE A SOURCE COMMENT?
         BNE   CMT_ITEM                NO, END OF COMMENTS FOR ITEM
         LA    R0,PRT_LINE+41+71       POINT PAST POSSIBLE COMMENT
         LA    R1,PRT_LINE+41+1        POINT TO POSSIBLE COMMENT
         MVC   CARD,BLANK              BLANK OUTPUT BUFFER
         B     CMT_LP_6                GO EXTRACT COMMENT

